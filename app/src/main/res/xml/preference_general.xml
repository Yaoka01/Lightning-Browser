<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory android:title="@string/settings_general">
        <SwitchPreference
            android:defaultValue="false"
            android:key="cb_images"
            android:title="@string/block"/>
        <SwitchPreference
            android:defaultValue="false"
            android:key="savedata"
            android:title="@string/save_data" />
        <SwitchPreference
            android:defaultValue="true"
            android:key="cb_javascript"
            android:title="@string/java"/>
        <SwitchPreference
            android:defaultValue="true"
            android:key="cb_colormode"
            android:title="@string/color_mode"/>
        <Preference
            android:key="proxy"
            android:title="@string/http_proxy"/>
        <Preference
            android:key="agent"
            android:title="@string/agent"/>
        <Preference
            android:key="download"
            android:title="@string/download"/>
        <Preference
            android:key="home"
            android:title="@string/home"/>
        <Preference
            android:key="search"
            android:title="@string/search"/>
        <Preference
            android:key="suggestions_choice"
            android:title="@string/search_suggestions"/>
        <androidx.preference.PreferenceCategory
            app:title="Advanced Mod">
        <androidx.preference.EditTextPreference
            app:key="custom_user_script"
            app:title="Custom UserScript (JS)"
            app:useEditTextService="true"
            app:dialogTitle="Input JavaScript Code"
            app:summary="Tulis kode JS di sini untuk dijalankan otomatis di setiap website" />
            
    </androidx.preference.PreferenceCategory>

    </PreferenceCategory>
</PreferenceScreen>
